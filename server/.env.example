# --- SERVER CONFIG ---
# The port the Express server will listen on
PORT=5001

# --- DATABASE ---
# Local: mongodb://127.0.0.1:27017/your-db-name
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/your-db-name
MONGODB_URI=your_mongodb_connection_string

# --- CORS & CLIENT ---
# The URL of your frontend application (for CORS policy)
CLIENT_URL=http://localhost:5173

# --- SECURITY ---
# A long, random string used to sign JWT tokens
JWT_SECRET=your_random_secret_string

# --- EMAIL (Optional) ---
# Used for Nodemailer features
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_specific_password
